# Local Docker Compose/demo profile.
# These credentials are local-only values for development and replay demos.
# The Rust code does not embed database or Redis URL fallbacks.
# In both profiles, SIGNALGUARD_DATABASE_URL and SIGNALGUARD_REDIS_URL must be set.
# Production-style runs must set explicit database and Redis URLs.
SIGNALGUARD_PROFILE=local
SIGNALGUARD_HOST=127.0.0.1
SIGNALGUARD_PORT=8080
SIGNALGUARD_DATABASE_URL=postgres://signalguard:signalguard@127.0.0.1:5432/signalguard
SIGNALGUARD_REDIS_URL=redis://127.0.0.1:6379
SIGNALGUARD_INGESTION_MODE=replay
SIGNALGUARD_INGESTION_SYMBOLS=BTCUSDT
SIGNALGUARD_INGESTION_REPLAY_PATH=examples/replay/sample.jsonl
SIGNALGUARD_INGESTION_REPLAY_DELAY_MS=0
# Bounded ingestion-to-pipeline channel capacity. Sources await when it is full.
SIGNALGUARD_EVENT_CHANNEL_CAPACITY=1024
SIGNALGUARD_REPLAY_RESET_STORAGE=true
SIGNALGUARD_BINANCE_WEBSOCKET_BASE_URL=wss://stream.binance.com:9443
SIGNALGUARD_BINANCE_RECONNECT_MIN_BACKOFF_MS=500
SIGNALGUARD_BINANCE_RECONNECT_MAX_BACKOFF_MS=5000
SIGNALGUARD_DETECTORS_PRICE_MOVE_1M_PCT_THRESHOLD=2.5
SIGNALGUARD_DETECTORS_SPREAD_SPIKE_PCT_THRESHOLD=0.5
SIGNALGUARD_DETECTORS_STALE_DATA_MS_THRESHOLD=5000
SIGNALGUARD_DETECTORS_TRADE_BURST_MULTIPLIER=3.0
SIGNALGUARD_DETECTORS_TRADE_BURST_MIN_WARMUP_WINDOWS=5
# Heuristic threshold for unchanged top-of-book signature while events continue.
SIGNALGUARD_DETECTORS_QUOTE_STUCK_MS_THRESHOLD=10000
# Heuristic threshold for ingest_time - event_time lag.
SIGNALGUARD_DETECTORS_EVENT_LAG_SPIKE_MS_THRESHOLD=3000
# Minimum increase in depth sequence gap count before emitting.
SIGNALGUARD_DETECTORS_DEPTH_SEQUENCE_GAP_MIN_INCREMENT=1
SIGNALGUARD_HEALTH_BASE_SCORE=100
SIGNALGUARD_HEALTH_INFO_PENALTY=5
SIGNALGUARD_HEALTH_WARNING_PENALTY=15
SIGNALGUARD_HEALTH_CRITICAL_PENALTY=35
SIGNALGUARD_HEALTH_STALE_DATA_PENALTY=25
SIGNALGUARD_HEALTH_RECENT_ANOMALY_WINDOW_SECS=300
SIGNALGUARD_HEALTH_HEALTHY_MIN_SCORE=80
SIGNALGUARD_HEALTH_DEGRADED_MIN_SCORE=50
RUST_LOG=signalguard_rs=info

# Production-style profile example:
# SIGNALGUARD_PROFILE=production
# SIGNALGUARD_DATABASE_URL=postgres://<user>:<password>@<host>:5432/<database>
# SIGNALGUARD_REDIS_URL=redis://<host>:6379
#
# In both local and production profiles, the service fails fast if
# SIGNALGUARD_DATABASE_URL or SIGNALGUARD_REDIS_URL is missing.
